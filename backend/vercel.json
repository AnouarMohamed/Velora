{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'Skipping Vite build'",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php?__path="
    }
  ]
}
